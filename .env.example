# ============================================================
# Beat the ASPP — Environment Variables Template
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys
# 3. NEVER commit .env to git — add it to .gitignore
# ============================================================

# --- REQUIRED (choose at least one LLM provider) ---
# Anthropic Claude (paid, highest quality): https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API (FREE, near GPT-4 quality, no download): https://console.groq.com/
# Sign up → API Keys → Create key. Free tier: 14,400 req/day.
GROQ_API_KEY=gsk_your-key-here

# --- OPTIONAL: Enhanced News Coverage ---
# NewsAPI (free tier: 100 requests/day): https://newsapi.org/
NEWS_API_KEY=your-newsapi-key-here

# --- OPTIONAL: SMTP (for password-reset emails) ---
# If unset, password-reset emails are written to data/dev_emails/ and
# printed to the server console (useful for local development).
# Gmail example: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com
SMTP_USE_TLS=1

# --- OPTIONAL: Telegram Alerts (free) ---
# 1. Open Telegram → @BotFather → /newbot → copy token
# 2. Start a chat with your bot, send any message
# 3. Get chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your_chat_id

# --- OPTIONAL: Micha.Stocks YouTube Summarizer (page 4) ---
# How to find a channel's UC-id (no API key needed):
#   1. Open the channel page in your browser (e.g. youtube.com/@MichaStocks)
#   2. View page source (Ctrl+U) and search for "channelId"
#   3. Copy the value that starts with "UC..." into the line below
# YOUTUBE_INITIAL_BACKLOG controls how many recent videos are summarized
# on the very first run for a brand-new user.
YOUTUBE_CHANNEL_ID=
YOUTUBE_INITIAL_BACKLOG=3
