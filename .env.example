# ============================================================
# Beat the ASPP — Environment Variables Template
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys
# 3. NEVER commit .env to git — add it to .gitignore
# ============================================================

# --- REQUIRED (choose at least one LLM provider) ---
# Anthropic Claude (paid, highest quality): https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API (FREE, near GPT-4 quality, no download): https://console.groq.com/
# Sign up → API Keys → Create key. Free tier: 14,400 req/day.
GROQ_API_KEY=gsk_your-key-here

# --- OPTIONAL: Enhanced News Coverage ---
# NewsAPI (free tier: 100 requests/day): https://newsapi.org/
NEWS_API_KEY=your-newsapi-key-here

# --- OPTIONAL: Telegram Alerts (free) ---
# 1. Open Telegram → @BotFather → /newbot → copy token
# 2. Start a chat with your bot, send any message
# 3. Get chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your_chat_id
